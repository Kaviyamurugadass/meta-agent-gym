# ---------------------------------------------------------------------------
# Hugging Face — required for openenv push + model uploads
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# LLM API — for baseline inference (inference.py) and LLM-as-judge
# Pick one of: OpenAI, OpenRouter (free models), Anthropic
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint (OpenRouter default is cheapest/free)
OPENAI_API_KEY=
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=meta-llama/llama-3.2-3b-instruct:free

# Anthropic — used if you route LLM-as-judge through Claude (Kube SRE pattern)
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Training run tracking (optional)
# ---------------------------------------------------------------------------
WANDB_API_KEY=
WANDB_PROJECT=openenv-r2

# ---------------------------------------------------------------------------
# Training config overrides (optional — CLI flags also work)
# ---------------------------------------------------------------------------
# BASE_MODEL=Qwen/Qwen3-0.6B
# MAX_SEQ_LENGTH=1024

# ---------------------------------------------------------------------------
# Server config
# ---------------------------------------------------------------------------
PORT=8000
MAX_CONCURRENT_ENVS=4

# ---------------------------------------------------------------------------
# Windows UTF-8 shim for openenv CLI (set to 1 if push fails with encoding)
# ---------------------------------------------------------------------------
PYTHONUTF8=1
